# =====================
# Java 编译输出文件
# =====================
# 忽略所有 .class 字节码文件
*.class

# 忽略默认的编译输出目录（根据项目不同，可能是 out 或 bin）
out/
bin/

# =====================
# IntelliJ IDEA 配置文件
# =====================
# IntelliJ 项目配置文件夹
.idea/

# IntelliJ 模块文件
*.iml
*.iws

# IntelliJ 编译输出（如果也叫 out）
out/

# =====================
# Eclipse IDE 配置文件
# =====================
.project
.classpath
.settings/

# =====================
# 操作系统产生的隐藏文件
# =====================
# macOS 文件系统产生的系统文件
.DS_Store

# Windows 缩略图缓存文件
Thumbs.db

# =====================
# 日志文件
# =====================
*.log

# =====================
# 临时文件和编辑器产生的备份文件
# =====================
# Vim 临时交换文件
*.swp

# Emacs 备份文件
*~

# 通用临时文件
*.tmp

# =====================
# Gradle 构建目录（如果使用 Gradle）
# =====================
.gradle/
build/

# =====================
# Maven 构建目录（如果使用 Maven）
# =====================
target/

# =====================
# 其他可能的临时文件
# =====================
# npm 依赖包（如果涉及 Node.js）
node_modules/

# =====================
# 备注
# =====================
# 如果你使用其他 IDE 或工具，根据实际情况补充对应的忽略规则。
